@{
    ViewData["Title"] = "Sudoku";
}

<style>
    /* Solve Path panel — scoped to this view so it stays out of the redesign's
       site.css. Uses the theme tokens, so it tracks light/dark automatically. */
    #steps-wrap.hidden { display: none; }
    .steps-header { display: flex; align-items: baseline; justify-content: space-between; gap: .5rem; }
    .steps-header .card-title { margin: 0; }
    .steps-summary { font-size: .72rem; color: var(--text-muted); }
    .steps-summary.ok   { color: var(--good); }
    .steps-summary.warn { color: var(--warn); }

    #steps-list {
        display: flex; flex-direction: column; gap: 4px;
        max-height: 420px; overflow-y: auto; margin-top: .6rem;
    }
    .step-item {
        display: flex; align-items: flex-start; gap: .5rem;
        width: 100%; text-align: left; padding: 6px 8px;
        border: 1px solid var(--border);
        border-left: 3px solid var(--border-strong);
        border-radius: var(--radius-sm);
        background: var(--panel-sunken); color: var(--text);
        cursor: pointer; font: inherit;
        transition: background .12s, border-color .12s;
    }
    .step-item:hover  { background: var(--accent-soft); border-color: var(--accent); }
    .step-item.active { background: var(--accent-soft); border-color: var(--accent); box-shadow: var(--shadow-sm); }
    .step-idx {
        flex: 0 0 auto; min-width: 1.3em; text-align: right;
        font-size: .72rem; color: var(--text-muted);
        font-variant-numeric: tabular-nums; padding-top: 1px;
    }
    .step-body { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .step-tech { font-size: .82rem; font-weight: 700; }
    .step-exp  { font-size: .72rem; color: var(--text-muted); line-height: 1.3; }
    .step-start .step-tech { color: var(--text-muted); font-weight: 600; }

    /* Tier colour scale (left border). Only tier 1 appears today; the rest are
       reserved so later techniques slot into the same visual language. */
    .tier-1 { border-left-color: #2e9e5b; }  /* singles */
    .tier-2 { border-left-color: #2f6df6; }  /* locked candidates */
    .tier-3 { border-left-color: #8a5cf6; }  /* subsets */
    .tier-4 { border-left-color: #d6457f; }  /* fish */
    .tier-5 { border-left-color: #e6810a; }  /* wings */
    .tier-6 { border-left-color: #d64545; }  /* chains */
    .tier-7 { border-left-color: #8a96ad; }  /* brute force */

    /* Board highlights shown while viewing a step. */
    .cell.evidence { background: var(--warn-bg); }
    .cell.placed   { background: var(--good-bg) !important; color: var(--good) !important; box-shadow: inset 0 0 0 2px var(--good); }
</style>

<div id="sudoku-app">
    <div class="app-header">
        <h1 class="app-title">Sudoku</h1>
        <div class="segmented" id="board-mode" title="Setter authors the puzzle (clues become givens); Solve plays it and protects givens">
            <button data-bmode="setter">Setter</button>
            <button data-bmode="solve" class="active">Solve</button>
        </div>
        <div class="header-spacer"></div>
        <span class="timer" id="timer">0:00</span>
        <button class="icon-btn" id="theme-toggle" title="Toggle light / dark" aria-label="Toggle theme">🌙</button>
    </div>

    <div class="sudoku-main">
        <div class="board-col">
            <div class="board-frame" id="board-frame">
                <div id="sudoku-board"></div>
            </div>
            <div id="status-bar" class="status-bar"></div>
        </div>

        <div class="controls-col">
            <!-- ── Input card: how you interact with the puzzle (self-contained) ── -->
            <div class="card-panel">
                <h2 class="card-title">Input</h2>
                <div class="segmented mode-selector" id="input-mode"
                     title="Normal: place a digit · Corner/Center: pencil marks (Shift / Ctrl+digit) · Color: tint cells">
                    <button data-mode="normal" class="active">Normal</button>
                    <button data-mode="corner">Corner</button>
                    <button data-mode="center">Center</button>
                    <button data-mode="color">Color</button>
                </div>

                <div id="numpad">
                    <button class="num-btn" data-n="1">1</button>
                    <button class="num-btn" data-n="2">2</button>
                    <button class="num-btn" data-n="3">3</button>
                    <button class="num-btn" data-n="4">4</button>
                    <button class="num-btn" data-n="5">5</button>
                    <button class="num-btn" data-n="6">6</button>
                    <button class="num-btn" data-n="7">7</button>
                    <button class="num-btn" data-n="8">8</button>
                    <button class="num-btn" data-n="9">9</button>
                    <button class="num-btn erase-btn" data-n="0">Erase</button>
                </div>

                <div class="color-palette hidden" id="color-palette">
                    <div class="swatch active" data-ci="1" style="background:var(--c1)"></div>
                    <div class="swatch" data-ci="2" style="background:var(--c2)"></div>
                    <div class="swatch" data-ci="3" style="background:var(--c3)"></div>
                    <div class="swatch" data-ci="4" style="background:var(--c4)"></div>
                    <div class="swatch" data-ci="5" style="background:var(--c5)"></div>
                    <div class="swatch" data-ci="6" style="background:var(--c6)"></div>
                    <div class="swatch" data-ci="7" style="background:var(--c7)"></div>
                    <div class="swatch erase" data-ci="0" title="Erase color">✕</div>
                </div>

                <div class="history-row">
                    <button class="btn-tool" id="btn-undo" title="Undo (Ctrl+Z)" disabled>↶ Undo</button>
                    <button class="btn-tool" id="btn-redo" title="Redo (Ctrl+Shift+Z)" disabled>↷ Redo</button>
                </div>
            </div>

            <!-- ── Puzzle-tools card: generation, testing, I/O (clearly separated) ── -->
            <div class="card-panel">
                <h2 class="card-title">Puzzle</h2>
                <div class="preset-row">
                    <button class="btn-preset" data-clues="36">Easy</button>
                    <button class="btn-preset" data-clues="30">Med</button>
                    <button class="btn-preset" data-clues="24">Hard</button>
                    <button class="btn-preset" data-clues="17">Expert</button>
                </div>
                <div class="clue-inline">
                    <span class="diff-label">Clues</span>
                    <input type="number" id="clue-count" min="17" max="80" value="30" />
                    <button id="btn-new" class="btn-tool btn-primary-tool">New Puzzle</button>
                </div>

                <div class="tools-grid">
                    <button id="btn-solve" class="btn-tool">Solve</button>
                    <button id="btn-analyze" class="btn-tool">Analyze</button>
                    <button id="btn-steps" class="btn-tool">Solve Path</button>
                    <button id="btn-clear" class="btn-tool">Clear Board</button>
                    <button id="btn-clear-givens" class="btn-tool">Clear Givens</button>
                    <button id="btn-export" class="btn-tool">Export .sudk</button>
                    <label class="btn-tool import-label">
                        Import .sudk
                        <input type="file" id="import-file" accept=".sudk" style="display:none" />
                    </label>
                </div>

                <div id="analyze-panel" class="analyze-panel hidden"></div>
            </div>

            <div class="card-panel hidden" id="steps-wrap">
                <div class="steps-header">
                    <h2 class="card-title">Solve Path</h2>
                    <span id="steps-summary" class="steps-summary"></span>
                </div>
                <div id="steps-list"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // ── Palette (digits 1–7 map to these in Color mode) ───────────────────────
    const PALETTE = ['var(--c1)','var(--c2)','var(--c3)','var(--c4)','var(--c5)','var(--c6)','var(--c7)'];

    // ── State ─────────────────────────────────────────────────────────────────
    let board       = new Array(81).fill(0);
    let givens      = new Array(81).fill(false);   // visual + (in solve mode) protected
    let cornerMarks = Array.from({length:81}, () => new Set());
    let centerMarks = Array.from({length:81}, () => new Set());
    let cellColors  = new Array(81).fill(null);
    let selected    = -1;
    let conflicts   = new Set();
    let won         = false;
    let mode        = 'normal';   // input mode: normal | corner | center | color
    let boardMode   = 'solve';    // setter | solve
    let activeColor = 1;          // 1..7 palette index, 0 = erase
    let seconds = 0, timerInterval = null;
    let undoStack = [], redoStack = [];

    // Solve-path (deductive solver) state
    let solvePathBase = null;   // the puzzle we solved, preserved across step navigation
    let pathSteps     = [];     // SolveStep[] from /api/sudoku/solve-steps
    let stepHighlight = null;   // { evidence:Set, placed:Set } — applied by renderBoard

    // ── Init ────────────────────────────────────────────────────────────────────
    buildGrid();
    bindEvents();
    updateThemeIcon();
    loadNewPuzzle();

    // ── Grid ──────────────────────────────────────────────────────────────────
    function buildGrid() {
        const el = document.getElementById('sudoku-board');
        el.innerHTML = '';
        const thin  = '1px solid var(--grid-thin)';
        const thick = '3px solid var(--grid-thick)';
        for (let i = 0; i < 81; i++) {
            const r = Math.floor(i / 9), c = i % 9;
            const cell = document.createElement('div');
            cell.className = 'cell';
            cell.dataset.idx = i;
            cell.tabIndex = 0;
            // Borders set once as inline styles — never affected by class/innerHTML changes
            cell.style.borderTop    = r === 0 ? 'none' : (r % 3 === 0 ? thick : thin);
            cell.style.borderLeft   = c === 0 ? 'none' : (c % 3 === 0 ? thick : thin);
            cell.style.borderRight  = 'none';
            cell.style.borderBottom = 'none';
            cell.addEventListener('click',   () => selectCell(i));
            cell.addEventListener('keydown', onCellKey);
            el.appendChild(cell);
        }
    }

    function renderBoard() {
        document.querySelectorAll('.cell').forEach((cell, i) => {
            // content: a big digit, OR pencil marks when empty
            let html = '';
            if (board[i]) {
                html = String(board[i]);
            } else {
                if (centerMarks[i].size)
                    html += `<span class="center-marks">${[...centerMarks[i]].sort().join('')}</span>`;
                if (cornerMarks[i].size)
                    html += `<div class="corner-marks">${[...cornerMarks[i]].sort().map(n => `<span>${n}</span>`).join('')}</div>`;
            }
            cell.innerHTML = html;

            cell.className = 'cell';
            if (givens[i]) cell.classList.add('given');
            // user color is an inline bg so it shows over peer/same-num tints;
            // selection/conflict/won use !important and intentionally show on top.
            cell.style.background = cellColors[i] || '';

            if (won) { cell.classList.add('won'); return; }
            if (i === selected)                                              cell.classList.add('selected');
            if (selected !== -1 && isPeer(i, selected))                      cell.classList.add('peer');
            if (selected !== -1 && board[i] && board[i] === board[selected]) cell.classList.add('same-num');
            if (conflicts.has(i))                                            cell.classList.add('conflict');
            if (stepHighlight) {
                if (stepHighlight.evidence.has(i)) cell.classList.add('evidence');
                if (stepHighlight.placed.has(i))   cell.classList.add('placed');
            }
        });
    }

    function isPeer(a, b) {
        if (a === b) return false;
        const ar = Math.floor(a / 9), ac = a % 9;
        const br = Math.floor(b / 9), bc = b % 9;
        return ar === br || ac === bc ||
            (Math.floor(ar/3) === Math.floor(br/3) && Math.floor(ac/3) === Math.floor(bc/3));
    }

    // ── Undo / redo ─────────────────────────────────────────────────────────────
    function cloneState() {
        return {
            board:       board.slice(),
            givens:      givens.slice(),
            cornerMarks: cornerMarks.map(s => [...s]),
            centerMarks: centerMarks.map(s => [...s]),
            cellColors:  cellColors.slice()
        };
    }
    function applyState(s) {
        board       = s.board.slice();
        givens      = s.givens.slice();
        cornerMarks = s.cornerMarks.map(a => new Set(a));
        centerMarks = s.centerMarks.map(a => new Set(a));
        cellColors  = s.cellColors.slice();
    }
    function pushHistory() {
        undoStack.push(cloneState());
        if (undoStack.length > 300) undoStack.shift();
        redoStack = [];
    }
    function undo() {
        if (!undoStack.length) return;
        redoStack.push(cloneState());
        applyState(undoStack.pop());
        afterHistoryJump();
    }
    function redo() {
        if (!redoStack.length) return;
        undoStack.push(cloneState());
        applyState(redoStack.pop());
        afterHistoryJump();
    }
    function afterHistoryJump() {
        conflicts = new Set();
        won = false;
        setStatus('');
        hideAnalyze();
        resetPath();
        if (boardMode === 'solve') checkWin();
        renderBoard();
        updateHistoryButtons();
    }
    function updateHistoryButtons() {
        document.getElementById('btn-undo').disabled = undoStack.length === 0;
        document.getElementById('btn-redo').disabled = redoStack.length === 0;
    }
    function clearHistory() { undoStack = []; redoStack = []; updateHistoryButtons(); }

    // ── Input ─────────────────────────────────────────────────────────────────
    function selectCell(i) {
        selected = i;
        if (mode === 'color') applyColor(i);   // painting in color mode
        else renderBoard();
    }

    function onCellKey(e) {
        const idx = parseInt(e.currentTarget.dataset.idx);
        if (e.key >= '1' && e.key <= '9') {
            const d = parseInt(e.key);
            if (e.shiftKey)                    enterValue(idx, d, 'corner');
            else if (e.ctrlKey || e.metaKey)   enterValue(idx, d, 'center');
            else                               enterValue(idx, d);
            e.preventDefault();
        }
        else if (e.key === 'Backspace' || e.key === 'Delete' || e.key === '0') { enterValue(idx, 0); e.preventDefault(); }
        else if (e.key === 'ArrowRight') navigate(idx,  0,  1);
        else if (e.key === 'ArrowLeft')  navigate(idx,  0, -1);
        else if (e.key === 'ArrowDown')  navigate(idx,  1,  0);
        else if (e.key === 'ArrowUp')    navigate(idx, -1,  0);
    }

    function navigate(idx, dr, dc) {
        const r = Math.floor(idx / 9) + dr, c = (idx % 9) + dc;
        if (r >= 0 && r < 9 && c >= 0 && c < 9) {
            const next = r * 9 + c;
            selected = next;
            renderBoard();
            document.querySelectorAll('.cell')[next].focus();
        }
    }

    // val: 0 = erase. forceMode overrides the active input mode (keyboard accelerators).
    function enterValue(idx, val, forceMode) {
        if (won) return;
        const m = forceMode || mode;

        // In Solve mode, givens are protected from digit changes.
        if (boardMode === 'solve' && givens[idx] && m === 'normal') return;

        pushHistory();

        if (m === 'normal') {
            board[idx] = val;
            if (val !== 0) { cornerMarks[idx].clear(); centerMarks[idx].clear(); }
            if (boardMode === 'setter') givens[idx] = (val !== 0);
        } else if (m === 'corner') {
            if (val === 0) cornerMarks[idx].clear();
            else if (board[idx] === 0) toggle(cornerMarks[idx], val);
        } else if (m === 'center') {
            if (val === 0) centerMarks[idx].clear();
            else if (board[idx] === 0) toggle(centerMarks[idx], val);
        } else if (m === 'color') {
            if (val === 0) cellColors[idx] = null;
            else if (val <= PALETTE.length) cellColors[idx] = PALETTE[val - 1];
        }

        conflicts = new Set();
        setStatus('');
        hideAnalyze();
        resetPath();
        if (boardMode === 'solve') checkWin();
        renderBoard();
        updateHistoryButtons();
    }

    function applyColor(idx) {
        if (won) return;
        pushHistory();
        cellColors[idx] = activeColor === 0 ? null : PALETTE[activeColor - 1];
        renderBoard();
        updateHistoryButtons();
    }

    function toggle(set, v) { set.has(v) ? set.delete(v) : set.add(v); }

    function checkWin() {
        if (board.includes(0)) { won = false; return; }
        if (localConflicts().length === 0) {
            won = true;
            stopTimer();
            setStatus('Solved! 🎉', 'success');
        }
    }

    function localConflicts() {
        const bad = new Set();
        const check = idxs => {
            const seen = {};
            for (const i of idxs) {
                const v = board[i];
                if (!v) continue;
                if (seen[v] !== undefined) { bad.add(seen[v]); bad.add(i); }
                else seen[v] = i;
            }
        };
        for (let r = 0; r < 9; r++) check(Array.from({length:9}, (_,c) => r*9+c));
        for (let c = 0; c < 9; c++) check(Array.from({length:9}, (_,r) => r*9+c));
        for (let br = 0; br < 3; br++)
        for (let bc = 0; bc < 3; bc++)
            check(Array.from({length:9}, (_,i) => (br*3+Math.floor(i/3))*9+(bc*3+i%3)));
        return [...bad];
    }

    // ── Modes ─────────────────────────────────────────────────────────────────
    function setMode(m) {
        mode = m;
        document.querySelectorAll('#input-mode button').forEach(b => b.classList.toggle('active', b.dataset.mode === m));
        document.getElementById('color-palette').classList.toggle('hidden', m !== 'color');
    }

    function setBoardMode(m) {
        applyBoardMode(m);
        won = false;
        if (m === 'solve') checkWin();
        setStatus(m === 'setter' ? 'Setter mode — typed digits become givens.' : '', m === 'setter' ? 'info' : '');
        renderBoard();
    }

    function applyBoardMode(m) {
        boardMode = m;
        document.querySelectorAll('#board-mode button').forEach(b => b.classList.toggle('active', b.dataset.bmode === m));
        document.getElementById('board-frame').classList.toggle('setter', m === 'setter');
    }

    // ── Theme ─────────────────────────────────────────────────────────────────
    function toggleTheme() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('sudoku-theme', next); } catch (e) { /* ignore */ }
        updateThemeIcon();
    }
    function updateThemeIcon() {
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        document.getElementById('theme-toggle').textContent = dark ? '☀' : '🌙';
    }

    // ── API ───────────────────────────────────────────────────────────────────
    function loadNewPuzzle() {
        const clues = clampClues(parseInt(document.getElementById('clue-count').value) || 30);
        document.getElementById('clue-count').value = clues;
        setStatus('Generating…');
        fetch(`/api/sudoku/new?clues=${clues}`)
            .then(r => r.json())
            .then(data => {
                board    = data.board;
                givens   = data.givens;
                resetMarks();
                selected = -1;
                conflicts = new Set();
                won = false;
                clearHistory();
                hideAnalyze();
                resetPath();
                applyBoardMode('solve');
                resetTimer();
                startTimer();
                setStatus('');
                renderBoard();
            });
    }

    function clearBoard() {
        pushHistory();
        board.fill(0);
        givens.fill(false);
        resetMarks();
        conflicts = new Set();
        won = false;
        selected = -1;
        hideAnalyze();
        resetPath();
        stopTimer();
        setStatus('');
        renderBoard();
        updateHistoryButtons();
    }

    function clearGivens() {
        pushHistory();
        givens.fill(false);
        setStatus('Givens cleared.', 'info');
        renderBoard();
        updateHistoryButtons();
    }

    function solveBoard() {
        fetch('/api/sudoku/solve', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ board })
        })
        .then(r => r.json())
        .then(data => {
            if (data.solvable) {
                pushHistory();
                board = data.board;
                resetPath();
                won = false;
                conflicts = new Set();
                stopTimer();
                setStatus('Puzzle solved.', 'info');
                updateHistoryButtons();
            } else {
                setStatus('No solution exists for this board.', 'error');
            }
            renderBoard();
        });
    }

    function analyzeBoard() {
        fetch('/api/sudoku/analyze', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ board })
        })
        .then(r => r.json())
        .then(data => {
            conflicts = new Set(data.conflicts || []);
            renderBoard();
            showAnalyze(data);
        });
    }

    function resetMarks() {
        cornerMarks = Array.from({length:81}, () => new Set());
        centerMarks = Array.from({length:81}, () => new Set());
        cellColors  = new Array(81).fill(null);
    }

    // ── Analyze panel ─────────────────────────────────────────────────────────
    function showAnalyze(data) {
        const panel = document.getElementById('analyze-panel');
        panel.classList.remove('hidden');
        const cls = data.solutionCount === 1 ? 'analyze-good'
                  : data.solutionCount === 0 ? 'analyze-bad'
                  : 'analyze-warn';
        panel.innerHTML = `<div class="analyze-result ${cls}">${data.message}</div>`;
    }
    function hideAnalyze() {
        const panel = document.getElementById('analyze-panel');
        panel.classList.add('hidden');
        panel.innerHTML = '';
    }

    // ── Solve path (deductive solver) ───────────────────────────────────────────
    function solvePath() {
        if (!solvePathBase) solvePathBase = board.slice();
        setStatus('Solving…');
        fetch('/api/sudoku/solve-steps', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ board: solvePathBase })
        })
        .then(r => r.json())
        .then(data => {
            pathSteps = data.steps || [];
            renderStepsList(data);
            setStatus('');
            showStep(-1);   // start node = puzzle as given
        });
    }

    function renderStepsList(data) {
        const wrap    = document.getElementById('steps-wrap');
        const list    = document.getElementById('steps-list');
        const summary = document.getElementById('steps-summary');
        wrap.classList.remove('hidden');

        const n = pathSteps.length;
        summary.textContent = data.solved
            ? `solved in ${n} step${n === 1 ? '' : 's'}`
            : `stopped after ${n} (needs more than singles)`;
        summary.className = 'steps-summary ' + (data.solved ? 'ok' : 'warn');

        let html = `<button class="step-item step-start" data-k="-1">
            <span class="step-idx">0</span>
            <span class="step-body"><span class="step-tech">Start</span>
            <span class="step-exp">puzzle as given</span></span></button>`;

        pathSteps.forEach((s, k) => {
            html += `<button class="step-item tier-${s.tier}" data-k="${k}">
                <span class="step-idx">${k + 1}</span>
                <span class="step-body">
                    <span class="step-tech">${s.technique}</span>
                    <span class="step-exp">${s.explanation}</span>
                </span></button>`;
        });
        list.innerHTML = html;

        list.querySelectorAll('.step-item').forEach(btn =>
            btn.addEventListener('click', () => showStep(parseInt(btn.dataset.k))));
    }

    // Viewing a solver step takes over the board display: show that snapshot on a
    // clean slate (no pencil marks / colors) so the evidence + placed highlights read.
    function showStep(k) {
        won = false;
        conflicts = new Set();
        selected = -1;
        resetMarks();

        if (k < 0) {
            board = solvePathBase.slice();
            stepHighlight = null;
        } else {
            const s = pathSteps[k];
            board = s.boardAfter.slice();
            stepHighlight = {
                evidence: new Set(s.evidenceCells || []),
                placed:   new Set((s.placements || []).map(p => p.cell))
            };
        }
        renderBoard();
        document.querySelectorAll('.step-item').forEach(btn =>
            btn.classList.toggle('active', parseInt(btn.dataset.k) === k));
    }

    function resetPath() {
        solvePathBase = null;
        pathSteps = [];
        stepHighlight = null;
        const wrap = document.getElementById('steps-wrap');
        if (wrap) wrap.classList.add('hidden');
        const list = document.getElementById('steps-list');
        if (list) list.innerHTML = '';
    }

    // ── Import / Export ─────────────────────────────────────────────────────────
    function exportBoard() {
        const payload = {
            board,
            givens,
            cornerMarks: cornerMarks.map(s => [...s]),
            centerMarks: centerMarks.map(s => [...s]),
            cellColors
        };
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
        const url  = URL.createObjectURL(blob);
        const a    = Object.assign(document.createElement('a'), { href: url, download: `sudoku-${Date.now()}.sudk` });
        a.click();
        URL.revokeObjectURL(url);
    }

    function importBoard(file) {
        const reader = new FileReader();
        reader.onload = e => {
            try {
                const data = JSON.parse(e.target.result);
                if (!Array.isArray(data.board) || data.board.length !== 81) throw new Error();
                board    = data.board.map(Number);
                givens   = Array.isArray(data.givens) ? data.givens.map(Boolean) : board.map(v => v !== 0);
                // new fields are optional — old {board,givens} files still import cleanly
                cornerMarks = hydrateMarks(data.cornerMarks);
                centerMarks = hydrateMarks(data.centerMarks);
                cellColors  = Array.isArray(data.cellColors) && data.cellColors.length === 81
                            ? data.cellColors.slice() : new Array(81).fill(null);
                selected = -1;
                conflicts = new Set();
                won = false;
                clearHistory();
                hideAnalyze();
                resetPath();
                stopTimer();
                document.getElementById('timer').textContent = '0:00';
                setStatus('Puzzle imported.', 'info');
                renderBoard();
            } catch {
                setStatus('Invalid .sudk file.', 'error');
            }
        };
        reader.readAsText(file);
    }

    function hydrateMarks(arr) {
        if (!Array.isArray(arr) || arr.length !== 81) return Array.from({length:81}, () => new Set());
        return arr.map(a => new Set(Array.isArray(a) ? a.map(Number) : []));
    }

    // ── Timer ─────────────────────────────────────────────────────────────────
    function resetTimer()  { stopTimer(); seconds = 0; document.getElementById('timer').textContent = '0:00'; }
    function startTimer()  { timerInterval = setInterval(() => { seconds++; document.getElementById('timer').textContent = fmt(seconds); }, 1000); }
    function stopTimer()   { clearInterval(timerInterval); timerInterval = null; }
    function fmt(s)        { return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`; }

    // ── Status ──────────────────────────────────────────────────────────────────
    function setStatus(msg, type = '') {
        const el = document.getElementById('status-bar');
        el.textContent = msg;
        el.className = 'status-bar' + (type ? ` status-${type}` : '');
    }

    function clampClues(n) { return Math.max(17, Math.min(80, isNaN(n) ? 30 : n)); }

    // ── Events ────────────────────────────────────────────────────────────────
    function bindEvents() {
        document.getElementById('btn-new').addEventListener('click', loadNewPuzzle);
        document.getElementById('btn-clear').addEventListener('click', clearBoard);
        document.getElementById('btn-clear-givens').addEventListener('click', clearGivens);
        document.getElementById('btn-solve').addEventListener('click', solveBoard);
        document.getElementById('btn-analyze').addEventListener('click', analyzeBoard);
        document.getElementById('btn-steps').addEventListener('click', solvePath);
        document.getElementById('btn-export').addEventListener('click', exportBoard);
        document.getElementById('btn-undo').addEventListener('click', undo);
        document.getElementById('btn-redo').addEventListener('click', redo);
        document.getElementById('theme-toggle').addEventListener('click', toggleTheme);

        document.getElementById('import-file').addEventListener('change', e => {
            if (e.target.files[0]) importBoard(e.target.files[0]);
            e.target.value = '';
        });

        // numpad — applies according to current mode
        document.querySelectorAll('.num-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (selected !== -1) enterValue(selected, parseInt(btn.dataset.n));
            });
        });

        // input-mode selector
        document.querySelectorAll('#input-mode button').forEach(btn => {
            btn.addEventListener('click', () => setMode(btn.dataset.mode));
        });

        // board-mode (setter / solve)
        document.querySelectorAll('#board-mode button').forEach(btn => {
            btn.addEventListener('click', () => setBoardMode(btn.dataset.bmode));
        });

        // color swatches
        document.querySelectorAll('.swatch').forEach(sw => {
            sw.addEventListener('click', () => {
                activeColor = parseInt(sw.dataset.ci);
                document.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
                sw.classList.add('active');
                if (selected !== -1) applyColor(selected);
            });
        });

        // difficulty presets
        document.querySelectorAll('.btn-preset').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('clue-count').value = btn.dataset.clues;
                document.querySelectorAll('.btn-preset').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });
        document.getElementById('clue-count').addEventListener('input', () => {
            document.querySelectorAll('.btn-preset').forEach(b => b.classList.remove('active'));
        });
        document.querySelector('.btn-preset[data-clues="30"]').classList.add('active');

        // global shortcuts: undo / redo
        document.addEventListener('keydown', e => {
            if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z') {
                e.preventDefault();
                e.shiftKey ? redo() : undo();
            } else if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'y') {
                e.preventDefault();
                redo();
            }
        });
    }
})();
</script>
}
