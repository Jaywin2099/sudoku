<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <!--
    This project sits at the repo root, so the SDK's default globs would
    otherwise sweep in the Sudoku.Tests/ subfolder (its sources and generated
    obj files), causing duplicate-attribute and missing-reference build errors.
    Exclude the test project from this app's build.
  -->
  <ItemGroup>
    <Compile Remove="Sudoku.Tests/**/*.cs" />
    <Content Remove="Sudoku.Tests/**/*" />
    <None Remove="Sudoku.Tests/**/*" />
    <EmbeddedResource Remove="Sudoku.Tests/**/*" />
  </ItemGroup>

</Project>
