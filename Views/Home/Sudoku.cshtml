@{
    ViewData["Title"] = "Sudoku";
}

<style>
    /* Solve Path panel — scoped to this view so it stays out of the redesign's
       site.css. Uses the theme tokens, so it tracks light/dark automatically. */
    #steps-wrap.hidden { display: none; }

    /* Solve Path is its own column on the right of the controls; widen the app
       only while it's open, so the default board + controls layout is untouched. */
    #sudoku-app.with-steps { max-width: 1320px; }
    #steps-wrap { flex: 0 0 460px; }

    /* Solve-path tree: YOU pick one move per column (your chosen path = the trunk),
       click an earlier node to re-branch. Each column = the moves available at that
       step. Lines: bold accent = your path; solid = a move REVEALED by your last pick;
       faded = a move that was available anyway (it converges regardless of path).
       The faint "if picked…" column previews where each unchosen move would lead;
       a ghost reached from several moves (many faint lines in) is a convergence point. */
    #explorer { position: relative; margin-top: .6rem; overflow: auto; max-height: 70vh; scroll-behavior: smooth; }
    .exflow { position: relative; display: flex; gap: 30px; padding: 8px 6px 12px; width: max-content; }
    #exsvg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; overflow: visible; z-index: 0; }
    .excol { flex: 0 0 auto; width: 80px; display: flex; flex-direction: column; gap: 10px; position: relative; z-index: 1; }
    .excol-head { font-size: .56rem; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); text-align: center; }
    .ghostcol .excol-head { color: color-mix(in srgb, var(--text-muted) 70%, transparent); font-style: italic; }
    .excol-nodes { display: flex; flex-direction: column; align-items: center; gap: 16px; }
    .exnode {
        width: 54px; height: 54px; flex: 0 0 auto; border-radius: 50%;
        border: 2px solid var(--border-strong); background: var(--panel); color: var(--text);
        cursor: pointer; font: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1px;
        transition: transform .08s, box-shadow .12s, background .12s;
    }
    /* Placement nodes = circles (singles, green/blue). Elimination nodes = rounded
       squares coloured by technique tier. */
    .exnode.naked  { border-color: #2e9e5b; }
    .exnode.hidden { border-color: #2f6df6; }
    .exnode.elim { border-radius: 13px; width: 66px; height: 50px; }
    .exnode.elim.tier2 { border-color: #d98324; }   /* locked candidates */
    .exnode.elim.tier3 { border-color: #8b5cf6; }   /* subsets */
    .exnode.elim.tier4 { border-color: #0ea5a5; }   /* fish */
    .exnode.elim.tier5 { border-color: #db2777; }   /* wings */
    .exnode:not(.ghost):hover { transform: scale(1.1); }
    .exnode.chosen { border-color: var(--accent); background: var(--accent-soft); box-shadow: 0 0 0 3px var(--accent-soft); }
    .exnode.ghost  { width: 42px; height: 42px; border-style: dashed; opacity: .5; cursor: default; background: transparent; }
    .exnode.ghost .exnode-dig { font-size: .9rem; }
    .exnode-dig  { font-size: 1.1rem; font-weight: 800; line-height: 1; }
    .exnode-cell { font-size: .5rem; color: var(--text-muted); }
    .exedge { fill: none; stroke: var(--text-muted); }
    .exedge.trunk    { stroke: var(--accent); stroke-width: 3.5; opacity: 1; }
    .exedge.revealed { stroke: var(--text); stroke-width: 2; opacity: .8; }
    .exedge.carried  { stroke: var(--text-muted); stroke-width: 1.4; opacity: .3; stroke-dasharray: 2 5; }
    .exedge.ghost    { stroke: var(--text-muted); stroke-width: 1.2; opacity: .32; stroke-dasharray: 4 4; }
    .excol-done  { font-size: .72rem; color: var(--text-muted); text-align: center; padding: .4rem 0; }
    /* legend */
    .exlegend { display: flex; flex-wrap: wrap; gap: .5rem 1rem; margin-top: .55rem; font-size: .62rem; color: var(--text-muted); }
    .exlegend span { display: inline-flex; align-items: center; gap: .3rem; }
    .exlegend i { width: 18px; height: 0; border-top-width: 3px; border-top-style: solid; display: inline-block; }
    .exlegend i.trunk    { border-color: var(--accent); }
    .exlegend i.revealed { border-color: var(--text); border-top-width: 2px; }
    .exlegend i.carried  { border-color: var(--text-muted); border-top-style: dashed; border-top-width: 2px; }
    .exlegend i.ghostl   { border-color: var(--text-muted); border-top-style: dashed; opacity: .5; border-top-width: 2px; }
    .exlegend b { font-weight: 800; font-size: .8rem; line-height: 1; }
    .exlegend b.lg-place  { color: #2e9e5b; }
    .exlegend b.lg-elim   { color: #8b5cf6; }
    .exlegend b.lg-strike { color: var(--bad); text-decoration: line-through; }
    .exlegend b.lg-block  { color: #2f6df6; }

    /* ── Setter vs Solve are different contexts: show only each mode's tools ──── */
    #sudoku-app.setter-mode .solve-only        { display: none !important; }
    #sudoku-app:not(.setter-mode) .setter-only { display: none !important; }

    /* Setter recolors the whole workspace amber (accent token swap) so switching
       reads as a context change, not a toggle. Translucent soft works on both themes. */
    #sudoku-app.setter-mode {
        --accent:       #d98324;
        --accent-hover: #c2731a;
        --accent-soft:  rgba(217, 131, 36, .16);
    }
    /* Setter also tints the whole page background a little amber (theme-aware) */
    body.setter-bg                     { --bg: #f6ecd6; }
    [data-theme="dark"] body.setter-bg { --bg: #17130b; }
    .mode-banner {
        display: flex; align-items: center; gap: .5rem;
        padding: .5rem .9rem;
        border: 1px solid var(--accent); border-radius: var(--radius);
        background: var(--accent-soft); color: var(--accent);
        font-weight: 700; font-size: .85rem;
    }

    /* Compact the numpad so the Input card isn't oversized in proportion */
    #numpad { gap: 6px; grid-template-columns: repeat(3, 48px); justify-content: center; }
    #numpad .num-btn   { height: 40px; font-size: 1.05rem; }
    #numpad .erase-btn { height: 34px; font-size: .82rem; }

    /* Scale the whole app down a touch */
    #sudoku-app { zoom: .95; }

    /* New ▾ generate popover — difficulty lives here instead of always on screen.
       Opens UPWARD (the button sits low in the column, so downward runs off-screen). */
    .action-row { display: flex; gap: 8px; margin-bottom: .7rem; }
    .action-row > .gen-wrap, .action-row > #btn-steps { flex: 1; }
    .gen-wrap { position: relative; }
    #btn-generate { width: 100%; }
    .gen-popover {
        position: absolute; bottom: calc(100% + 6px); left: 0; z-index: 30;
        width: 230px; max-width: 80vw;
        display: flex; flex-direction: column; gap: .6rem;
        padding: .8rem; border-radius: var(--radius);
        background: var(--panel); border: 1px solid var(--border); box-shadow: var(--shadow);
    }
    .gen-popover.hidden { display: none; }
    .gen-go { width: 100%; }
    .steps-header { display: flex; align-items: baseline; justify-content: space-between; gap: .5rem; }
    .steps-header .card-title { margin: 0; }
    .steps-summary { font-size: .72rem; color: var(--text-muted); }
    .steps-summary.ok   { color: var(--good); }
    .steps-summary.warn { color: var(--warn); }

    #steps-list {
        display: flex; flex-direction: column; gap: 4px;
        max-height: 420px; overflow-y: auto; margin-top: .6rem;
    }
    .step-item {
        display: flex; align-items: flex-start; gap: .5rem;
        width: 100%; text-align: left; padding: 6px 8px;
        border: 1px solid var(--border);
        border-left: 3px solid var(--border-strong);
        border-radius: var(--radius-sm);
        background: var(--panel-sunken); color: var(--text);
        cursor: pointer; font: inherit;
        transition: background .12s, border-color .12s;
    }
    .step-item:hover  { background: var(--accent-soft); border-color: var(--accent); }
    .step-item.active { background: var(--accent-soft); border-color: var(--accent); box-shadow: var(--shadow-sm); }
    .step-idx {
        flex: 0 0 auto; min-width: 1.3em; text-align: right;
        font-size: .72rem; color: var(--text-muted);
        font-variant-numeric: tabular-nums; padding-top: 1px;
    }
    .step-body { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .step-tech { font-size: .82rem; font-weight: 700; }
    .step-exp  { font-size: .72rem; color: var(--text-muted); line-height: 1.3; }
    .step-start .step-tech { color: var(--text-muted); font-weight: 600; }

    /* Tier colour scale (left border). Only tier 1 appears today; the rest are
       reserved so later techniques slot into the same visual language. */
    .tier-1 { border-left-color: #2e9e5b; }  /* singles */
    .tier-2 { border-left-color: #2f6df6; }  /* locked candidates */
    .tier-3 { border-left-color: #8a5cf6; }  /* subsets */
    .tier-4 { border-left-color: #d6457f; }  /* fish */
    .tier-5 { border-left-color: #e6810a; }  /* wings */
    .tier-6 { border-left-color: #d64545; }  /* chains */
    .tier-7 { border-left-color: #8a96ad; }  /* brute force */

    /* Board highlights shown while viewing a step. The whole UNIT the technique reasoned
       in gets a clear wash (so "hidden single in row 5" visibly lights up row 5); the
       evidence cells go amber; an ELIMINATION strikes the removed candidate(s) in red so
       you can SEE it act (it changes candidates, not the board); a placed single previews
       in green; and a hidden single rings the existing digits that force it (its blockers,
       i.e. why it can't go anywhere else in the unit). */
    .cell.hl-unit  { background: color-mix(in srgb, var(--accent) 20%, var(--cell)); }
    .cell.evidence { background: var(--warn-bg) !important; }
    .cell.removed  { background: var(--bad-bg) !important; box-shadow: inset 0 0 0 2px var(--bad); }
    .cell.placed   { background: var(--good-bg) !important; color: var(--good) !important; box-shadow: inset 0 0 0 2px var(--good); }
    .cell.blocker  { box-shadow: inset 0 0 0 3px #2f6df6; }   /* existing digits that force a hidden single */
    .cell .cand-place  { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
                         color: var(--good); font-weight: 800; font-size: 1.5rem; opacity: .9; pointer-events: none; z-index: 2; }
    /* Plain-English read-out of the hovered / chosen move — externalises the reasoning. */
    .exnote { margin-top: .55rem; min-height: 1.1rem; font-size: .74rem; line-height: 1.4; color: var(--text); }
    .exnote:empty { display: none; }
    .exnote-kind { display: block; margin-top: .15rem; color: var(--text-muted); font-style: italic; font-size: .68rem; }
    .show-all-toggle { font-size: .68rem; color: var(--text-muted); display: inline-flex; align-items: center; gap: .3rem; cursor: pointer; user-select: none; }
    .show-all-toggle input { accent-color: var(--accent); margin: 0; }

    /* ── Startup welcome popup (replaces the old header/footer chrome) ─────────── */
    .welcome-overlay {
        position: fixed; inset: 0; z-index: 100;
        display: flex; align-items: center; justify-content: center;
        padding: 1rem; background: rgba(12, 17, 28, .5);
    }
    .welcome-overlay.hidden { display: none; }
    .welcome-card {
        background: var(--panel); color: var(--text);
        border: 1px solid var(--border); border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1.6rem 1.7rem; width: min(92vw, 420px); text-align: center;
    }
    .welcome-title { font-size: 1.8rem; font-weight: 800; letter-spacing: -.02em; margin: 0 0 .3rem; }
    .welcome-sub   { color: var(--text-muted); font-size: .88rem; line-height: 1.45; margin: 0 0 1.2rem; }
    .welcome-section { margin-top: 1rem; }
    .welcome-label { display: block; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; color: var(--text-muted); margin-bottom: .5rem; }
    .welcome-diffs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
    #welcome-create { width: 100%; }
</style>

<div id="sudoku-app">
    <div class="app-header">
        <h1 class="app-title">Sudoku</h1>
        <div class="segmented" id="board-mode" title="Setter authors the puzzle (clues become givens); Solve plays it and protects givens">
            <button data-bmode="setter">Setter</button>
            <button data-bmode="solve" class="active">Solve</button>
        </div>
        <div class="header-spacer"></div>
        <span class="timer solve-only" id="timer">0:00</span>
        <button class="icon-btn" id="theme-toggle" title="Toggle light / dark" aria-label="Toggle theme">🌙</button>
    </div>

    <div class="sudoku-main">
        <div class="board-col">
            <div class="board-frame" id="board-frame">
                <div id="sudoku-board"></div>
            </div>
            <div id="status-bar" class="status-bar"></div>
        </div>

        <div class="controls-col">
            <!-- ── Input card: how you interact with the puzzle (self-contained) ── -->
            <div class="card-panel">
                <h2 class="card-title">Input</h2>
                <div class="segmented mode-selector solve-only" id="input-mode"
                     title="Normal: place a digit · Notes: candidate marks (Shift+digit), shown 1–9 in fixed positions">
                    <button data-mode="normal" class="active">Normal</button>
                    <button data-mode="notes">Notes</button>
                </div>

                <div id="numpad">
                    <button class="num-btn" data-n="1">1</button>
                    <button class="num-btn" data-n="2">2</button>
                    <button class="num-btn" data-n="3">3</button>
                    <button class="num-btn" data-n="4">4</button>
                    <button class="num-btn" data-n="5">5</button>
                    <button class="num-btn" data-n="6">6</button>
                    <button class="num-btn" data-n="7">7</button>
                    <button class="num-btn" data-n="8">8</button>
                    <button class="num-btn" data-n="9">9</button>
                    <button class="num-btn erase-btn" data-n="0">Erase</button>
                </div>

                <div class="color-palette hidden" id="color-palette">
                    <div class="swatch active" data-ci="1" style="background:var(--c1)"></div>
                    <div class="swatch" data-ci="2" style="background:var(--c2)"></div>
                    <div class="swatch" data-ci="3" style="background:var(--c3)"></div>
                    <div class="swatch" data-ci="4" style="background:var(--c4)"></div>
                    <div class="swatch" data-ci="5" style="background:var(--c5)"></div>
                    <div class="swatch" data-ci="6" style="background:var(--c6)"></div>
                    <div class="swatch" data-ci="7" style="background:var(--c7)"></div>
                    <div class="swatch erase" data-ci="0" title="Erase color">✕</div>
                </div>

                <div class="history-row">
                    <button class="btn-tool" id="btn-undo" title="Undo (Ctrl+Z)" disabled>↶ Undo</button>
                    <button class="btn-tool" id="btn-redo" title="Redo (Ctrl+Shift+Z)" disabled>↷ Redo</button>
                </div>
            </div>

            <!-- ── Actions card: New (popover) + Solve Path always; authoring tools are setter-only ── -->
            <div class="card-panel">
                <h2 class="card-title">Actions</h2>

                <div class="action-row">
                    <div class="gen-wrap">
                        <button id="btn-generate" class="btn-tool btn-primary-tool" aria-haspopup="true" aria-expanded="false">New ▾</button>
                        <div class="gen-popover hidden" id="gen-popover">
                            <div class="preset-row">
                                <button class="btn-preset" data-clues="36">Easy</button>
                                <button class="btn-preset" data-clues="30">Med</button>
                                <button class="btn-preset" data-clues="24">Hard</button>
                                <button class="btn-preset" data-clues="17">Expert</button>
                            </div>
                            <div class="clue-inline">
                                <span class="diff-label">Clues</span>
                                <input type="number" id="clue-count" min="17" max="80" value="30" />
                            </div>
                            <button id="btn-new" class="btn-tool btn-primary-tool gen-go">Generate</button>
                        </div>
                    </div>
                    <button id="btn-steps" class="btn-tool setter-only">Solve Path</button>
                </div>

                <div class="tools-grid setter-only">
                    <button id="btn-solve" class="btn-tool">Solve</button>
                    <button id="btn-analyze" class="btn-tool">Analyze</button>
                    <button id="btn-clear" class="btn-tool">Clear Board</button>
                    <button id="btn-clear-givens" class="btn-tool">Clear Givens</button>
                    <button id="btn-export" class="btn-tool">Export .sudk</button>
                    <label class="btn-tool import-label">
                        Import .sudk
                        <input type="file" id="import-file" accept=".sudk" style="display:none" />
                    </label>
                </div>

                <div id="analyze-panel" class="analyze-panel hidden"></div>
            </div>
        </div>

        <div class="card-panel hidden" id="steps-wrap">
            <div class="steps-header">
                <h2 class="card-title">Solve Path</h2>
                <label class="show-all-toggle" title="Fill every empty cell with its remaining candidates, so you can watch eliminations strike them out">
                    <input type="checkbox" id="show-all-cands"> all candidates
                </label>
                <span id="steps-summary" class="steps-summary"></span>
            </div>
            <div id="explorer"></div>
            <div id="exnote" class="exnote"></div>
            <div class="exlegend">
                <span><b class="lg-place">●</b>places a digit</span>
                <span><b class="lg-elim">▢</b>eliminates (colour = technique)</span>
                <span><b class="lg-strike">5</b>candidate removed</span>
                <span><b class="lg-block">◎</b>forces a hidden single</span>
                <span><i class="trunk"></i>your path</span>
                <span><i class="revealed"></i>revealed by your move</span>
                <span><i class="carried"></i>available anyway</span>
                <span><i class="ghostl"></i>if you'd picked that</span>
            </div>
        </div>
    </div>
</div>

<div class="welcome-overlay" id="welcome">
    <div class="welcome-card">
        <h1 class="welcome-title">Sudoku</h1>
        <p class="welcome-sub">Generate and solve puzzles, or author your own — Setter mode gives you a step-by-step Solve Path to check it.</p>
        <div class="welcome-section">
            <span class="welcome-label">Play a puzzle</span>
            <div class="welcome-diffs">
                <button class="btn-tool" data-start-clues="36">Easy</button>
                <button class="btn-tool" data-start-clues="30">Medium</button>
                <button class="btn-tool" data-start-clues="24">Hard</button>
                <button class="btn-tool" data-start-clues="17">Expert</button>
            </div>
        </div>
        <div class="welcome-section">
            <button class="btn-tool btn-primary-tool" id="welcome-create">Create your own →</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // ── Palette (digits 1–7 map to these in Color mode) ───────────────────────
    const PALETTE = ['var(--c1)','var(--c2)','var(--c3)','var(--c4)','var(--c5)','var(--c6)','var(--c7)'];

    // ── State ─────────────────────────────────────────────────────────────────
    let board       = new Array(81).fill(0);
    let givens      = new Array(81).fill(false);   // visual + (in solve mode) protected
    let marks = Array.from({length:81}, () => new Set());   // one candidate-note set per cell (positional 1–9)
    let showAllCands = false;                                // explorer: fill empty cells with their remaining candidates
    let cellColors  = new Array(81).fill(null);
    let selected    = -1;
    let conflicts   = new Set();
    let won         = false;
    let mode        = 'normal';   // input mode: normal | corner | center | color
    let boardMode   = 'solve';    // setter | solve
    let activeColor = 1;          // 1..7 palette index, 0 = erase
    let seconds = 0, timerInterval = null;
    let undoStack = [], redoStack = [];

    // Solve-path tree state — the MODEL is the server endpoint /api/sudoku/moves
    // (view-agnostic: board -> all legal single moves). The path you click through is
    // built entirely from that one model, so other front-ends can render it differently.
    let explorerBase = null;    // board the path started from
    let explorerPath = [];      // your chosen moves, in order (each a SolveStep from /moves)
    let explorerCols = [];      // moves[] available at each column (0..frontier)
    let stepHighlight = null;   // { units:Set, evidence:Set, blockers:Set, removedDigits:Map, placedDigit } — applied by renderBoard
    const moveCache  = new Map();// board-string -> moves[] (a board always yields the same set)

    // ── Init ────────────────────────────────────────────────────────────────────
    buildGrid();
    bindEvents();
    updateThemeIcon();
    loadNewPuzzle();

    // ── Grid ──────────────────────────────────────────────────────────────────
    function buildGrid() {
        const el = document.getElementById('sudoku-board');
        el.innerHTML = '';
        const thin  = '1px solid var(--grid-thin)';
        const thick = '3px solid var(--grid-thick)';
        for (let i = 0; i < 81; i++) {
            const r = Math.floor(i / 9), c = i % 9;
            const cell = document.createElement('div');
            cell.className = 'cell';
            cell.dataset.idx = i;
            cell.tabIndex = 0;
            // Borders set once as inline styles — never affected by class/innerHTML changes
            cell.style.borderTop    = r === 0 ? 'none' : (r % 3 === 0 ? thick : thin);
            cell.style.borderLeft   = c === 0 ? 'none' : (c % 3 === 0 ? thick : thin);
            cell.style.borderRight  = 'none';
            cell.style.borderBottom = 'none';
            cell.addEventListener('click',   () => selectCell(i));
            cell.addEventListener('keydown', onCellKey);
            el.appendChild(cell);
        }
    }

    function renderBoard() {
        // Explorer candidate grid (for "show all" and elimination strikes), computed once.
        const candSets = explorerBase ? currentCandSets() : null;
        document.querySelectorAll('.cell').forEach((cell, i) => {
            // content: a big digit, OR candidate marks when empty
            let html = '';
            if (board[i]) {
                html = String(board[i]);
            } else {
                const isPlaced = stepHighlight && stepHighlight.placedDigit && stepHighlight.placedDigit.cell === i;
                const touched  = stepHighlight && stepHighlight.removedDigits.has(i);
                if (candSets && (showAllCands || touched) && !isPlaced) {
                    // explorer: solver candidates — every empty cell when "show all" is on,
                    // otherwise just the cells this move touches; strike what it removes.
                    const struck = touched ? new Set(stepHighlight.removedDigits.get(i)) : null;
                    html += candGridHtml(candSets[i], struck, true);
                } else if (!isPlaced && marks[i].size) {
                    html += candGridHtml(marks[i], null, false);   // the player's own notes
                }
                if (isPlaced) html += `<span class="cand-place">${stepHighlight.placedDigit.digit}</span>`;
            }
            cell.innerHTML = html;

            cell.className = 'cell';
            if (givens[i]) cell.classList.add('given');
            // user color is an inline bg so it shows over peer/same-num tints;
            // selection/conflict/won use !important and intentionally show on top.
            cell.style.background = cellColors[i] || '';

            if (won) { cell.classList.add('won'); return; }
            if (i === selected)                                              cell.classList.add('selected');
            if (selected !== -1 && isPeer(i, selected))                      cell.classList.add('peer');
            if (selected !== -1 && board[i] && board[i] === board[selected]) cell.classList.add('same-num');
            if (conflicts.has(i))                                            cell.classList.add('conflict');
            if (stepHighlight) {
                if (inAnyUnit(i, stepHighlight.units))                                  cell.classList.add('hl-unit');
                if (stepHighlight.evidence.has(i))                                      cell.classList.add('evidence');
                if (stepHighlight.blockers.has(i))                                      cell.classList.add('blocker');
                if (!board[i] && stepHighlight.removedDigits.has(i))                    cell.classList.add('removed');
                if (stepHighlight.placedDigit && stepHighlight.placedDigit.cell === i)  cell.classList.add('placed');
            }
        });
    }

    function isPeer(a, b) {
        if (a === b) return false;
        const ar = Math.floor(a / 9), ac = a % 9;
        const br = Math.floor(b / 9), bc = b % 9;
        return ar === br || ac === bc ||
            (Math.floor(ar/3) === Math.floor(br/3) && Math.floor(ac/3) === Math.floor(bc/3));
    }

    // ── Undo / redo ─────────────────────────────────────────────────────────────
    function cloneState() {
        return {
            board:      board.slice(),
            givens:     givens.slice(),
            marks:      marks.map(s => [...s]),
            cellColors: cellColors.slice()
        };
    }
    function applyState(s) {
        board      = s.board.slice();
        givens     = s.givens.slice();
        marks      = s.marks.map(a => new Set(a));
        cellColors = s.cellColors.slice();
    }
    function pushHistory() {
        undoStack.push(cloneState());
        if (undoStack.length > 300) undoStack.shift();
        redoStack = [];
    }
    function undo() {
        if (!undoStack.length) return;
        redoStack.push(cloneState());
        applyState(undoStack.pop());
        afterHistoryJump();
    }
    function redo() {
        if (!redoStack.length) return;
        undoStack.push(cloneState());
        applyState(redoStack.pop());
        afterHistoryJump();
    }
    function afterHistoryJump() {
        conflicts = new Set();
        won = false;
        setStatus('');
        hideAnalyze();
        resetPath();
        if (boardMode === 'solve') checkWin();
        renderBoard();
        updateHistoryButtons();
    }
    function updateHistoryButtons() {
        document.getElementById('btn-undo').disabled = undoStack.length === 0;
        document.getElementById('btn-redo').disabled = redoStack.length === 0;
    }
    function clearHistory() { undoStack = []; redoStack = []; updateHistoryButtons(); }

    // ── Input ─────────────────────────────────────────────────────────────────
    function selectCell(i) {
        selected = i;
        if (mode === 'color') applyColor(i);   // painting in color mode
        else renderBoard();
    }

    function onCellKey(e) {
        const idx = parseInt(e.currentTarget.dataset.idx);
        if (e.key >= '1' && e.key <= '9') {
            const d = parseInt(e.key);
            if (e.shiftKey || e.ctrlKey || e.metaKey) enterValue(idx, d, 'notes');   // either accelerator = candidate note
            else                                      enterValue(idx, d);
            e.preventDefault();
        }
        else if (e.key === 'Backspace' || e.key === 'Delete' || e.key === '0') { enterValue(idx, 0); e.preventDefault(); }
        else if (e.key === 'ArrowRight') navigate(idx,  0,  1);
        else if (e.key === 'ArrowLeft')  navigate(idx,  0, -1);
        else if (e.key === 'ArrowDown')  navigate(idx,  1,  0);
        else if (e.key === 'ArrowUp')    navigate(idx, -1,  0);
    }

    function navigate(idx, dr, dc) {
        const r = Math.floor(idx / 9) + dr, c = (idx % 9) + dc;
        if (r >= 0 && r < 9 && c >= 0 && c < 9) {
            const next = r * 9 + c;
            selected = next;
            renderBoard();
            document.querySelectorAll('.cell')[next].focus();
        }
    }

    // val: 0 = erase. forceMode overrides the active input mode (keyboard accelerators).
    function enterValue(idx, val, forceMode) {
        if (won) return;
        const m = forceMode || mode;

        // In Solve mode, givens are protected from digit changes.
        if (boardMode === 'solve' && givens[idx] && m === 'normal') return;

        pushHistory();

        if (m === 'normal') {
            board[idx] = val;
            if (val !== 0) marks[idx].clear();
            if (boardMode === 'setter') givens[idx] = (val !== 0);
        } else if (m === 'notes') {
            if (val === 0) marks[idx].clear();
            else if (board[idx] === 0) toggle(marks[idx], val);
        } else if (m === 'color') {
            if (val === 0) cellColors[idx] = null;
            else if (val <= PALETTE.length) cellColors[idx] = PALETTE[val - 1];
        }

        conflicts = new Set();
        setStatus('');
        hideAnalyze();
        resetPath();
        if (boardMode === 'solve') checkWin();
        renderBoard();
        updateHistoryButtons();
    }

    function applyColor(idx) {
        if (won) return;
        pushHistory();
        cellColors[idx] = activeColor === 0 ? null : PALETTE[activeColor - 1];
        renderBoard();
        updateHistoryButtons();
    }

    function toggle(set, v) { set.has(v) ? set.delete(v) : set.add(v); }

    function checkWin() {
        if (board.includes(0)) { won = false; return; }
        if (localConflicts().length === 0) {
            won = true;
            stopTimer();
            setStatus('Solved! 🎉', 'success');
        }
    }

    function localConflicts() {
        const bad = new Set();
        const check = idxs => {
            const seen = {};
            for (const i of idxs) {
                const v = board[i];
                if (!v) continue;
                if (seen[v] !== undefined) { bad.add(seen[v]); bad.add(i); }
                else seen[v] = i;
            }
        };
        for (let r = 0; r < 9; r++) check(Array.from({length:9}, (_,c) => r*9+c));
        for (let c = 0; c < 9; c++) check(Array.from({length:9}, (_,r) => r*9+c));
        for (let br = 0; br < 3; br++)
        for (let bc = 0; bc < 3; bc++)
            check(Array.from({length:9}, (_,i) => (br*3+Math.floor(i/3))*9+(bc*3+i%3)));
        return [...bad];
    }

    // ── Modes ─────────────────────────────────────────────────────────────────
    function setMode(m) {
        mode = m;
        document.querySelectorAll('#input-mode button').forEach(b => b.classList.toggle('active', b.dataset.mode === m));
        document.getElementById('color-palette').classList.toggle('hidden', m !== 'color');
    }

    function setBoardMode(m) {
        applyBoardMode(m);
        won = false;
        resetPath();
        if (m === 'solve') checkWin();
        setStatus('');
        renderBoard();
    }

    function applyBoardMode(m) {
        boardMode = m;
        document.querySelectorAll('#board-mode button').forEach(b => b.classList.toggle('active', b.dataset.bmode === m));
        document.getElementById('board-frame').classList.toggle('setter', m === 'setter');
        document.getElementById('sudoku-app').classList.toggle('setter-mode', m === 'setter');
        document.body.classList.toggle('setter-bg', m === 'setter');
    }

    // ── Generate popover (difficulty lives here, off the New ▾ button) ───────────
    function toggleGenPopover(e) {
        if (e) e.stopPropagation();
        const open = !document.getElementById('gen-popover').classList.toggle('hidden');
        document.getElementById('btn-generate').setAttribute('aria-expanded', open);
    }
    function closeGenPopover() {
        document.getElementById('gen-popover').classList.add('hidden');
        document.getElementById('btn-generate').setAttribute('aria-expanded', 'false');
    }

    // ── Theme ─────────────────────────────────────────────────────────────────
    function toggleTheme() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('sudoku-theme', next); } catch (e) { /* ignore */ }
        updateThemeIcon();
    }
    function updateThemeIcon() {
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        document.getElementById('theme-toggle').textContent = dark ? '☀' : '🌙';
    }

    // ── Startup welcome ─────────────────────────────────────────────────────────
    function hideWelcome() { document.getElementById('welcome').classList.add('hidden'); }
    function startFromWelcome(clues) {
        document.getElementById('clue-count').value = clues;
        loadNewPuzzle();
        hideWelcome();
    }

    // ── API ───────────────────────────────────────────────────────────────────
    function loadNewPuzzle() {
        closeGenPopover();
        const clues = clampClues(parseInt(document.getElementById('clue-count').value) || 30);
        document.getElementById('clue-count').value = clues;
        setStatus('Generating…');
        fetch(`/api/sudoku/new?clues=${clues}`)
            .then(r => r.json())
            .then(data => {
                board    = data.board;
                givens   = data.givens;
                resetMarks();
                selected = -1;
                conflicts = new Set();
                won = false;
                clearHistory();
                hideAnalyze();
                resetPath();
                applyBoardMode('solve');
                resetTimer();
                startTimer();
                setStatus('');
                renderBoard();
            });
    }

    function clearBoard() {
        pushHistory();
        board.fill(0);
        givens.fill(false);
        resetMarks();
        conflicts = new Set();
        won = false;
        selected = -1;
        hideAnalyze();
        resetPath();
        stopTimer();
        setStatus('');
        renderBoard();
        updateHistoryButtons();
    }

    function clearGivens() {
        pushHistory();
        givens.fill(false);
        setStatus('Givens cleared.', 'info');
        renderBoard();
        updateHistoryButtons();
    }

    function solveBoard() {
        fetch('/api/sudoku/solve', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ board })
        })
        .then(r => r.json())
        .then(data => {
            if (data.solvable) {
                pushHistory();
                board = data.board;
                resetPath();
                won = false;
                conflicts = new Set();
                stopTimer();
                setStatus('Puzzle solved.', 'info');
                updateHistoryButtons();
            } else {
                setStatus('No solution exists for this board.', 'error');
            }
            renderBoard();
        });
    }

    function analyzeBoard() {
        fetch('/api/sudoku/analyze', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ board })
        })
        .then(r => r.json())
        .then(data => {
            conflicts = new Set(data.conflicts || []);
            renderBoard();
            showAnalyze(data);
        });
    }

    function resetMarks() {
        marks = Array.from({length:81}, () => new Set());
        cellColors  = new Array(81).fill(null);
    }

    // ── Analyze panel ─────────────────────────────────────────────────────────
    function showAnalyze(data) {
        const panel = document.getElementById('analyze-panel');
        panel.classList.remove('hidden');
        const cls = data.solutionCount === 1 ? 'analyze-good'
                  : data.solutionCount === 0 ? 'analyze-bad'
                  : 'analyze-warn';
        panel.innerHTML = `<div class="analyze-result ${cls}">${data.message}</div>`;
    }
    function hideAnalyze() {
        const panel = document.getElementById('analyze-panel');
        panel.classList.add('hidden');
        panel.innerHTML = '';
    }

    // ── Solve-path tree ─────────────────────────────────────────────────────────
    // The MODEL is the server endpoint /api/sudoku/moves (board -> all legal single
    // moves). YOU build a path: each column is the moves available at that step;
    // click one to play it (the trunk grows, one cell at a time), click an earlier
    // node to re-branch (truncate the path and head off differently). The lines tell
    // the story: bold accent = your path; solid = a move your last pick REVEALED;
    // faded = a move that was available anyway (it converges regardless of path).
    // A faint "if picked…" column previews where each unchosen move would lead, and a
    // ghost reached by several moves (many faint lines in) is a convergence point.
    function solvePath() {
        explorerBase = board.slice();
        explorerPath = [];
        document.getElementById('steps-wrap').classList.remove('hidden');
        document.getElementById('sudoku-app').classList.add('with-steps');
        showHead();
        renderExplorer();
    }

    function resetPath() {
        explorerBase = null; explorerPath = []; explorerCols = []; stepHighlight = null;
        const wrap = document.getElementById('steps-wrap');
        if (wrap) wrap.classList.add('hidden');
        document.getElementById('sudoku-app').classList.remove('with-steps');
        const ex = document.getElementById('explorer');
        if (ex) ex.innerHTML = '';
        showNote(null);
    }

    function boardAtColumn(i) { return i === 0 ? explorerBase : explorerPath[i - 1].boardAfter; }
    function candsAtColumn(i) { return i === 0 ? null : explorerPath[i - 1].candsAfter; }

    // A move's stable identity, so the same deduction is matched across columns.
    function moveSig(m) {
        const pl = (m.placements || []).map(p => p.cell + ':' + p.digit).join(',');
        const el = (m.eliminations || []).map(e => e.cell + ':' + e.digit).sort().join(',');
        return m.technique + '|' + pl + '|' + el;
    }
    // Big glyph for an elimination node: the single digit it removes, or (for subsets
    // touching several digits) how many distinct digits it removes.
    function elimGlyph(m) {
        const digs = [...new Set((m.eliminations || []).map(e => e.digit))];
        return digs.length === 1 ? digs[0] : digs.length;
    }
    // What a move USED (cells + units) and DID (removed candidates / placed digit),
    // for board highlighting.
    function highlightFromMove(m) {
        const removedDigits = new Map();                 // cell -> [digits] struck by this move
        for (const e of (m.eliminations || [])) {
            if (!removedDigits.has(e.cell)) removedDigits.set(e.cell, []);
            removedDigits.get(e.cell).push(e.digit);
        }
        const placedDigit = m.places && (m.placements || []).length
            ? { cell: m.placements[0].cell, digit: m.placements[0].digit } : null;
        // Hidden single: ring the existing digits that FORCE it. In its unit every other
        // empty cell is blocked from the digit by one of these, so the deduction is
        // self-evident — you can see why the digit can't go anywhere else in the unit.
        const blockers = new Set();
        if (m.technique === 'Hidden Single' && placedDigit && (m.evidenceUnits || []).length) {
            const before = m.boardAfter.slice(); before[placedDigit.cell] = 0;
            for (const c of cellsInUnit(m.evidenceUnits[0])) {
                if (c === placedDigit.cell || before[c] !== 0) continue;
                for (const p of peersOf(c)) if (before[p] === placedDigit.digit) blockers.add(p);
            }
        }
        return {
            units:    new Set(m.evidenceUnits || []),
            evidence: new Set(m.evidenceCells || []),
            blockers, removedDigits, placedDigit
        };
    }
    function cellsInUnit(u) { const out = []; for (let i = 0; i < 81; i++) if (inAnyUnit(i, [u])) out.push(i); return out; }
    function peersOf(c)     { const out = []; for (let i = 0; i < 81; i++) if (i !== c && isPeer(i, c)) out.push(i); return out; }

    // One positional candidate grid: digit d sits in its fixed row-major slot (1 = top-left
    // … 9 = bottom-right), struck digits crossed out in red. Used for the player's notes and
    // the explorer's "show all candidates".
    function candGridHtml(digits, struck, isAll) {
        let spans = '';
        for (let d = 1; d <= 9; d++) {
            if (!digits.has(d)) { spans += '<span></span>'; continue; }
            spans += `<span${struck && struck.has(d) ? ' class="struck"' : ''}>${d}</span>`;
        }
        return `<div class="cand-grid${isAll ? ' all' : ''}">${spans}</div>`;
    }
    // Candidate sets for the state currently shown in the explorer (its head). Uses the
    // threaded candidate grid when a move has been played (so earlier eliminations are
    // reflected), else basic candidates of the base board.
    function currentCandSets() {
        if (!explorerBase) return null;
        const mask = explorerPath.length ? explorerPath[explorerPath.length - 1].candsAfter : null;
        return mask ? maskToSets(mask) : basicCands(board);
    }
    function maskToSets(mask) {
        return Array.from({length:81}, (_, i) => {
            const s = new Set();
            for (let d = 1; d <= 9; d++) if (mask[i] & (1 << (d - 1))) s.add(d);
            return s;
        });
    }
    function basicCands(bd) {
        const out = Array.from({length:81}, () => new Set());
        for (let i = 0; i < 81; i++) {
            if (bd[i]) continue;
            for (let d = 1; d <= 9; d++) if (!peerHasDigit(bd, i, d)) out[i].add(d);
        }
        return out;
    }
    function peerHasDigit(bd, c, d) {
        const r = Math.floor(c / 9), col = c % 9;
        for (let k = 0; k < 9; k++) if (bd[r*9+k] === d || bd[k*9+col] === d) return true;
        const br = Math.floor(r/3)*3, bc = Math.floor(col/3)*3;
        for (let dr = 0; dr < 3; dr++) for (let dc = 0; dc < 3; dc++) if (bd[(br+dr)*9+(bc+dc)] === d) return true;
        return false;
    }
    // Plain-English read-out of a move (or clear). Externalises the reasoning so a correct
    // deduction reads as correct without trusting the node alone.
    function showNote(m) {
        const note = document.getElementById('exnote');
        if (!note) return;
        if (!m) { note.innerHTML = ''; return; }
        const kind = m.places ? 'Places a digit.'
                              : 'Removes candidates — changes the pencil marks, not the board (which is why it unlocks moves later, not now).';
        note.innerHTML = `<strong>${esc(m.technique)}</strong> — ${esc(m.explanation)}<span class="exnote-kind">${kind}</span>`;
    }
    // Is a cell inside any of the given units? (0-8 rows, 9-17 cols, 18-26 boxes)
    function inAnyUnit(cell, units) {
        const r = Math.floor(cell / 9), c = cell % 9;
        for (const u of units) {
            if (u < 9) { if (r === u) return true; }
            else if (u < 18) { if (c === u - 9) return true; }
            else { const b = u - 18, br = Math.floor(b / 3) * 3, bc = (b % 3) * 3;
                   if (r >= br && r < br + 3 && c >= bc && c < bc + 3) return true; }
        }
        return false;
    }
    const TECH_ABBR = {
        'Naked Single': 'single', 'Hidden Single': 'single',
        'Pointing Pair': 'point·2', 'Pointing Triple': 'point·3',
        'Claiming Pair': 'claim·2', 'Claiming Triple': 'claim·3',
        'Naked Pair': 'n.pair', 'Naked Triple': 'n.triple', 'Naked Quad': 'n.quad',
        'Hidden Pair': 'h.pair', 'Hidden Triple': 'h.triple', 'Hidden Quad': 'h.quad',
        'X-Wing': 'X-Wing', 'Swordfish': 'sword', 'Jellyfish': 'jelly',
        'XY-Wing': 'XY-Wing', 'XYZ-Wing': 'XYZ-Wing'
    };
    const esc = s => (s || '').replace(/"/g, '&quot;');

    // The board on screen follows the head (last picked move), or the base if none.
    function showHead() {
        won = false; conflicts = new Set(); selected = -1; resetMarks();
        if (explorerPath.length === 0) {
            board = explorerBase.slice();
            stepHighlight = null;
            showNote(null);
        } else {
            const last = explorerPath[explorerPath.length - 1];
            board = last.boardAfter.slice();
            stepHighlight = highlightFromMove(last);
            showNote(last);
        }
        renderBoard();
    }

    function chooseMove(col, move) {
        if (!move) return;
        explorerPath = explorerPath.slice(0, col).concat([move]);   // re-branch + extend
        showHead();
        renderExplorer();
    }

    // MODEL fetch: all legal moves for a board+candidate state, cached. Passing the
    // candidate grid threads earlier eliminations forward (an elimination changes the
    // candidates, not the board), so the next column reflects what it unlocked.
    async function movesFor(bd, cds) {
        const key = bd.join(',') + '|' + (cds ? cds.join(',') : '');
        if (moveCache.has(key)) return moveCache.get(key);
        const resp = await fetch('/api/sudoku/moves', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ board: bd, cands: cds })
        });
        const moves = (await resp.json()).moves || [];
        moveCache.set(key, moves);
        return moves;
    }

    async function renderExplorer() {
        const ex = document.getElementById('explorer');
        const summary = document.getElementById('steps-summary');
        const frontier = explorerPath.length;

        // Real columns: every move available at each step 0..frontier (singles +
        // every elimination technique), threading candidates forward.
        explorerCols = [];
        for (let i = 0; i <= frontier; i++) explorerCols.push(await movesFor(boardAtColumn(i), candsAtColumn(i)));
        const sigMaps = explorerCols.map(ms => { const map = new Map(); ms.forEach((mv, mi) => map.set(moveSig(mv), mi)); return map; });

        // Frontier ghosts: for each move available now, peek one step ahead and collect
        // the SINGLES it would unlock (a placement not already available). A ghost cell
        // reached from several moves (many faint lines in) is a convergence point.
        const frontMoves = explorerCols[frontier];
        const frontPlaceCells = new Set(frontMoves.filter(m => m.places).map(m => m.placements[0].cell));
        const ghosts = new Map();   // cell -> { digit, parents:Set<frontier mi> }
        for (let mi = 0; mi < frontMoves.length; mi++) {
            const opt = frontMoves[mi];
            const after = await movesFor(opt.boardAfter, opt.candsAfter);
            for (const m of after) {
                if (!m.places) continue;                          // preview unlocked singles only
                const gc = m.placements[0].cell;
                if (frontPlaceCells.has(gc)) continue;            // already placeable, not newly unlocked
                if (!ghosts.has(gc)) ghosts.set(gc, { digit: m.placements[0].digit, parents: new Set() });
                ghosts.get(gc).parents.add(mi);
            }
        }

        // Render columns. Singles = circles (place a digit); eliminations = rounded
        // squares coloured by tier (click to apply and see what they unlock).
        let cols = '';
        explorerCols.forEach((moves, i) => {
            const chosenSig = i < frontier ? moveSig(explorerPath[i]) : null;
            let nodes;
            if (moves.length === 0) {
                nodes = `<div class="excol-done">${boardAtColumn(i).includes(0) ? 'no moves' : 'solved ✓'}</div>`;
            } else {
                nodes = moves.map((m, mi) => {
                    const sel = moveSig(m) === chosenSig ? ' chosen' : '';
                    if (m.places) {
                        const cell = m.placements[0].cell, digit = m.placements[0].digit;
                        const kind = m.technique === 'Naked Single' ? 'naked' : 'hidden';
                        return `<button class="exnode place ${kind}${sel}" data-col="${i}" data-mi="${mi}" title="${esc(m.explanation)}">
                                    <span class="exnode-dig">${digit}</span><span class="exnode-cell">${rc(cell)}</span>
                                </button>`;
                    }
                    return `<button class="exnode elim tier${m.tier}${sel}" data-col="${i}" data-mi="${mi}" title="${esc(m.explanation)}">
                                <span class="exnode-dig">${elimGlyph(m)}</span><span class="exnode-cell">${TECH_ABBR[m.technique] || m.technique}</span>
                            </button>`;
                }).join('');
            }
            const head = i === 0 ? 'start' : (i === frontier ? 'now' : 'step ' + i);
            cols += `<div class="excol"><div class="excol-head">${head}</div><div class="excol-nodes">${nodes}</div></div>`;
        });

        // Ghost column: faint preview of the singles each unchosen move would unlock.
        if (ghosts.size) {
            const gnodes = [...ghosts.entries()].map(([gc, info]) =>
                `<div class="exnode ghost" data-gcell="${gc}" title="unlocks ${rc(gc)} = ${info.digit}">
                    <span class="exnode-dig">${info.digit}</span><span class="exnode-cell">${rc(gc)}</span>
                 </div>`).join('');
            cols += `<div class="excol ghostcol"><div class="excol-head">if picked…</div><div class="excol-nodes">${gnodes}</div></div>`;
        }

        ex.innerHTML = `<div class="exflow"><svg id="exsvg"></svg>${cols}</div>`;
        drawEdges(sigMaps, ghosts, frontier);

        // Real nodes: click to play, hover to preview what the move uses/does on the board.
        ex.querySelectorAll('.exnode[data-mi]').forEach(btn => {
            const move = explorerCols[+btn.dataset.col][+btn.dataset.mi];
            btn.addEventListener('click', () => chooseMove(+btn.dataset.col, move));
            btn.addEventListener('mouseenter', () => { stepHighlight = highlightFromMove(move); showNote(move); renderBoard(); });
            btn.addEventListener('mouseleave', showHead);
        });

        if (summary) {
            const fm = explorerCols[frontier];
            summary.textContent = fm.length ? `${fm.length} move${fm.length === 1 ? '' : 's'} now`
                                 : boardAtColumn(frontier).includes(0) ? 'stuck' : 'solved ✓';
        }
        ex.scrollLeft = ex.scrollWidth;   // keep the frontier in view
    }

    // Draw the tree edges as SVG curves. The <svg> lives INSIDE .exflow (the scrolling
    // content), so coordinates are content-relative and stay aligned at any scroll.
    function drawEdges(sigMaps, ghosts, frontier) {
        const ex = document.getElementById('explorer');
        const flow = ex.querySelector('.exflow');
        const svg = ex.querySelector('#exsvg');
        if (!flow || !svg) return;

        const W = flow.scrollWidth, H = flow.scrollHeight;
        svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
        svg.setAttribute('width', W); svg.setAttribute('height', H);
        const fr = flow.getBoundingClientRect();

        const posSel = sel => {
            const el = ex.querySelector(sel);
            if (!el) return null;
            const r = el.getBoundingClientRect();
            return { x: r.left - fr.left, y: r.top - fr.top + r.height / 2, w: r.width };
        };
        const posCM = (col, mi) => posSel(`.exnode[data-col="${col}"][data-mi="${mi}"]`);
        const posG  = cell => posSel(`.exnode.ghost[data-gcell="${cell}"]`);
        const curve = (a, b, cls) => {
            const x1 = a.x + a.w, y1 = a.y, x2 = b.x, y2 = b.y, dx = Math.max(20, (x2 - x1) / 2);
            return `<path d="M${x1},${y1} C${x1 + dx},${y1} ${x2 - dx},${y2} ${x2},${y2}" class="exedge ${cls}"/>`;
        };

        let paths = '';
        // For each chosen move, draw into the next column: trunk to the next chosen,
        // solid to the moves it REVEALED (new this column), faded lifeline to moves that
        // were already available in the previous column (carried — convergent).
        for (let i = 0; i < frontier; i++) {
            const chosenSig = moveSig(explorerPath[i]);
            const aMi = sigMaps[i].get(chosenSig);
            const a = aMi != null ? posCM(i, aMi) : null;
            if (!a) continue;
            const nextChosenSig = i + 1 < frontier ? moveSig(explorerPath[i + 1]) : null;
            explorerCols[i + 1].forEach((m, mi) => {
                const b = posCM(i + 1, mi);
                if (!b) return;
                const s = moveSig(m);
                if (s === nextChosenSig) { paths += curve(a, b, 'trunk'); return; }
                if (sigMaps[i].has(s)) { const a2 = posCM(i, sigMaps[i].get(s)); if (a2) paths += curve(a2, b, 'carried'); }
                else paths += curve(a, b, 'revealed');
            });
        }
        // Ghost previews: each unchosen frontier move → the singles it would unlock.
        ghosts.forEach((info, gc) => {
            const g = posG(gc);
            if (!g) return;
            info.parents.forEach(mi => { const p = posCM(frontier, mi); if (p) paths += curve(p, g, 'ghost'); });
        });
        svg.innerHTML = paths;
    }

    function rc(cell) { return 'R' + (Math.floor(cell / 9) + 1) + 'C' + (cell % 9 + 1); }

    // ── Import / Export ─────────────────────────────────────────────────────────
    function exportBoard() {
        const payload = {
            board,
            givens,
            marks: marks.map(s => [...s]),
            cellColors
        };
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
        const url  = URL.createObjectURL(blob);
        const a    = Object.assign(document.createElement('a'), { href: url, download: `sudoku-${Date.now()}.sudk` });
        a.click();
        URL.revokeObjectURL(url);
    }

    function importBoard(file) {
        const reader = new FileReader();
        reader.onload = e => {
            try {
                const data = JSON.parse(e.target.result);
                if (!Array.isArray(data.board) || data.board.length !== 81) throw new Error();
                board    = data.board.map(Number);
                givens   = Array.isArray(data.givens) ? data.givens.map(Boolean) : board.map(v => v !== 0);
                // new fields are optional — old {board,givens} files still import cleanly.
                // Legacy files had separate corner/center marks; merge them into the one set.
                marks = data.marks ? hydrateMarks(data.marks)
                                   : mergeMarks(data.cornerMarks, data.centerMarks);
                cellColors  = Array.isArray(data.cellColors) && data.cellColors.length === 81
                            ? data.cellColors.slice() : new Array(81).fill(null);
                selected = -1;
                conflicts = new Set();
                won = false;
                clearHistory();
                hideAnalyze();
                resetPath();
                stopTimer();
                document.getElementById('timer').textContent = '0:00';
                setStatus('Puzzle imported.', 'info');
                renderBoard();
            } catch {
                setStatus('Invalid .sudk file.', 'error');
            }
        };
        reader.readAsText(file);
    }

    function hydrateMarks(arr) {
        if (!Array.isArray(arr) || arr.length !== 81) return Array.from({length:81}, () => new Set());
        return arr.map(a => new Set(Array.isArray(a) ? a.map(Number) : []));
    }
    // Legacy .sudk had separate corner + center marks; fold both into the single set.
    function mergeMarks(corner, center) {
        const a = hydrateMarks(corner), b = hydrateMarks(center);
        return a.map((s, i) => new Set([...s, ...b[i]]));
    }

    // ── Timer ─────────────────────────────────────────────────────────────────
    function resetTimer()  { stopTimer(); seconds = 0; document.getElementById('timer').textContent = '0:00'; }
    function startTimer()  { timerInterval = setInterval(() => { seconds++; document.getElementById('timer').textContent = fmt(seconds); }, 1000); }
    function stopTimer()   { clearInterval(timerInterval); timerInterval = null; }
    function fmt(s)        { return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`; }

    // ── Status ──────────────────────────────────────────────────────────────────
    function setStatus(msg, type = '') {
        const el = document.getElementById('status-bar');
        el.textContent = msg;
        el.className = 'status-bar' + (type ? ` status-${type}` : '');
    }

    function clampClues(n) { return Math.max(17, Math.min(80, isNaN(n) ? 30 : n)); }

    // ── Events ────────────────────────────────────────────────────────────────
    function bindEvents() {
        document.getElementById('btn-new').addEventListener('click', loadNewPuzzle);
        document.getElementById('btn-clear').addEventListener('click', clearBoard);
        document.getElementById('btn-clear-givens').addEventListener('click', clearGivens);
        document.getElementById('btn-solve').addEventListener('click', solveBoard);
        document.getElementById('btn-analyze').addEventListener('click', analyzeBoard);
        document.getElementById('btn-steps').addEventListener('click', solvePath);
        window.addEventListener('resize', () => { if (explorerBase) renderExplorer(); });
        document.getElementById('btn-export').addEventListener('click', exportBoard);
        document.getElementById('btn-undo').addEventListener('click', undo);
        document.getElementById('btn-redo').addEventListener('click', redo);
        document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
        document.getElementById('btn-generate').addEventListener('click', toggleGenPopover);
        document.addEventListener('click', e => { if (!e.target.closest('.gen-wrap')) closeGenPopover(); });

        // welcome popup
        document.querySelectorAll('#welcome [data-start-clues]').forEach(btn =>
            btn.addEventListener('click', () => startFromWelcome(btn.dataset.startClues)));
        document.getElementById('welcome-create').addEventListener('click', () => {
            clearBoard(); setBoardMode('setter'); hideWelcome();
        });
        document.getElementById('welcome').addEventListener('click', e => {
            if (e.target.id === 'welcome') hideWelcome();
        });

        document.getElementById('import-file').addEventListener('change', e => {
            if (e.target.files[0]) importBoard(e.target.files[0]);
            e.target.value = '';
        });

        // numpad — applies according to current mode
        document.querySelectorAll('.num-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (selected !== -1) enterValue(selected, parseInt(btn.dataset.n));
            });
        });

        // input-mode selector
        document.querySelectorAll('#input-mode button').forEach(btn => {
            btn.addEventListener('click', () => setMode(btn.dataset.mode));
        });

        // explorer: "show all candidates" toggle
        document.getElementById('show-all-cands').addEventListener('change', e => {
            showAllCands = e.target.checked;
            renderBoard();
        });

        // board-mode (setter / solve)
        document.querySelectorAll('#board-mode button').forEach(btn => {
            btn.addEventListener('click', () => setBoardMode(btn.dataset.bmode));
        });

        // color swatches
        document.querySelectorAll('.swatch').forEach(sw => {
            sw.addEventListener('click', () => {
                activeColor = parseInt(sw.dataset.ci);
                document.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
                sw.classList.add('active');
                if (selected !== -1) applyColor(selected);
            });
        });

        // difficulty presets
        document.querySelectorAll('.btn-preset').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('clue-count').value = btn.dataset.clues;
                document.querySelectorAll('.btn-preset').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });
        document.getElementById('clue-count').addEventListener('input', () => {
            document.querySelectorAll('.btn-preset').forEach(b => b.classList.remove('active'));
        });
        document.querySelector('.btn-preset[data-clues="30"]').classList.add('active');

        // global shortcuts: Esc closes the New popover, Ctrl+Z / Ctrl+Y undo / redo
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { closeGenPopover(); return; }
            if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z') {
                e.preventDefault();
                e.shiftKey ? redo() : undo();
            } else if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'y') {
                e.preventDefault();
                redo();
            }
        });
    }
})();
</script>
}
